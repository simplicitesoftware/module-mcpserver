{
  "devDependencies": {
    "eslint": "latest",
    "stylelint": "latest",
    "@eslint/js": "latest",
    "stylelint-config-standard-less": "latest",
    "jshint": "latest",
    "globals": "latest",
    "stylelint-config-standard": "latest",
    "@stylistic/stylelint-plugin": "latest"
  },
  "name": "MCPServer",
  "scripts": {
    "eslint": "eslint --config=.eslint-configuration.mjs --no-color --no-error-on-unmatched-pattern resources/**/*.js",
    "stylelint": "stylelint --config=.stylelint-configuration.mjs --no-color --allow-empty-input resources/**/*.css resources/**/*.less",
    "jshint": "jshint --config=.jshint-configuration.json --reporter=jslint resources"
  },
  "version": "0.1"
}